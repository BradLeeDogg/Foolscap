# Fetch better-sqlite3's prebuilt binary for Electron instead of compiling from
# source. This makes `npm install` work without Visual Studio C++ Build Tools.
#
# `prebuild-install` (run by better-sqlite3's install script) downloads the
# binary matching this runtime/target. Keep `target` aligned with the major
# Electron version in package.json (devDependencies.electron).
runtime=electron
target=33.4.11
disturl=https://electronjs.org/headers
